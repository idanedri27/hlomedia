# =====================================================================
# HloMedia - Environment Variables
#
# Copy this file to .env (which is gitignored) and fill in real values.
# On the production VPS, set these via CloudPanel → Settings → PHP-FPM
# environment vars, or via Apache SetEnv in .htaccess (NOT recommended
# for secrets - SetEnv is visible to all PHP processes).
# =====================================================================

# ---- Local MySQL (used by blog homepage + sitemap.php) --------------
DB_HOST=localhost
DB_NAME=hlomedia
DB_USER=root
DB_PASSWORD=

# ---- Central SEO Platform API (overrides defaults in seo-platform-config.php)
# Leave blank to use the public per-site api_key baked into the config.
SEO_PLATFORM_API_URL=https://api.hlo-media.com/lead.php
SEO_PLATFORM_API_KEY=
SEO_PLATFORM_TIMEOUT=10
SEO_PLATFORM_FALLBACK_EMAIL=idanedri27@gmail.com
